{
  "name": "omnireplyai",
  "version": "1.0.0",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/server.ts",
    "dev:worker": "nodemon --exec ts-node src/worker.ts",
    "build": "tsc",
    "db:migrate": "prisma migrate deploy --schema prisma/schema.prisma",
    "start": "npm run db:migrate && node dist/server.js",
    "worker": "node dist/worker.js",
    "test": "vitest run tests --reporter=verbose",
    "test:automation": "vitest run tests/automation --reporter=verbose",
    "test:security": "vitest run tests/security --reporter=verbose",
    "audit:security": "npm run test:security && npm audit --audit-level=moderate",
    "db:check": "node scripts/db-connectivity-check.js",
    "db:pull": "prisma db pull --schema prisma/schema.prisma"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "whatsapp",
    "saas",
    "ai",
    "multi-tenant"
  ],
  "author": "OmniReply AI",
  "license": "ISC",
  "description": "Multi-Tenant WhatsApp SaaS for Local Businesses — AI-Powered Customer Support",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^6.19.2",
    "@supabase/supabase-js": "^2.78.0",
    "@whiskeysockets/baileys": "^6.17.16",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "franc-min": "^6.2.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "qrcode-terminal": "^0.12.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.2.3",
    "@types/supertest": "^7.2.0",
    "nodemon": "^3.1.11",
    "prisma": "^6.19.2",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}

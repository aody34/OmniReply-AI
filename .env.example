NODE_ENV=development
PORT=3000

DATABASE_URL=postgresql://USER:PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require
# Optional: set DIRECT_URL when you want Prisma migrations to prefer a different direct host.
DIRECT_URL=postgresql://USER:PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
# Optional alias if your platform uses this name instead:
# SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

JWT_SECRET=replace-with-your-app-jwt-secret
JWT_EXPIRES_IN=7d
GEMINI_API_KEY=your-gemini-api-key

CORS_ORIGIN=https://omni-reply-ai.vercel.app,http://localhost:3000,http://localhost:5173
TRUST_PROXY=false
BODY_LIMIT=1mb

WHATSAPP_SESSION_ENC_KEY=replace-with-a-32-byte-random-secret
WEBHOOK_SECRET=replace-with-a-webhook-shared-secret
ENABLE_WHATSAPP_RECONNECT_ON_BOOT=false
ENABLE_PENDING_REPLY_WORKER=true
PENDING_REPLY_POLL_INTERVAL_MS=15000
GEMINI_MODEL=gemini-1.5-flash

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3000
BACKEND_API_URL=http://localhost:3000

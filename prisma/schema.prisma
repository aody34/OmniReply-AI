generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Broadcast {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId    String    @db.Uuid
  message     String
  recipients  String[]  @default([])
  sentCount   Int?      @default(0)
  failedCount Int?      @default(0)
  status      String?   @default("pending")
  scheduledAt DateTime? @db.Timestamptz(6)
  completedAt DateTime? @db.Timestamptz(6)
  createdAt   DateTime? @default(now()) @db.Timestamptz(6)
  Tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([tenantId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model DailyStat {
  id             String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId       String    @db.Uuid
  date           DateTime  @db.Date
  messagesIn     Int?      @default(0)
  messagesOut    Int?      @default(0)
  aiResponses    Int?      @default(0)
  newLeads       Int?      @default(0)
  broadcastsSent Int?      @default(0)
  createdAt      DateTime? @default(now()) @db.Timestamptz(6)
  Tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([tenantId, date], map: "DailyStat_tenant_date_idx")
  @@index([tenantId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model KnowledgeEntry {
  id        String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId  String    @db.Uuid
  category  String
  title     String
  content   String
  isActive  Boolean?  @default(true)
  createdAt DateTime? @default(now()) @db.Timestamptz(6)
  updatedAt DateTime? @default(now()) @db.Timestamptz(6)
  Tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([tenantId, category], map: "KnowledgeEntry_category_idx")
  @@index([tenantId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Lead {
  id           String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId     String    @db.Uuid
  phone        String
  name         String?
  firstMessage String?
  messageCount Int?      @default(1)
  lastContact  DateTime? @default(now()) @db.Timestamptz(6)
  tags         String[]  @default([])
  createdAt    DateTime? @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime? @default(now()) @db.Timestamptz(6)
  Tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([tenantId, phone], map: "Lead_tenant_phone_idx")
  @@index([tenantId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model MessageLog {
  id        String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId  String    @db.Uuid
  direction String
  phone     String
  message   String
  language  String?
  aiModel   String?
  createdAt DateTime? @default(now()) @db.Timestamptz(6)
  Tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([tenantId, phone], map: "MessageLog_phone_idx")
  @@index([tenantId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Tenant {
  id               String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name             String
  businessType     String?          @default("general")
  plan             String?          @default("free")
  maxDailyMessages Int?             @default(100)
  isActive         Boolean?         @default(true)
  aiPersonality    String?          @default("professional")
  createdAt        DateTime?        @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime?        @default(now()) @db.Timestamptz(6)
  Broadcast        Broadcast[]
  DailyStat        DailyStat[]
  KnowledgeEntry   KnowledgeEntry[]
  Lead             Lead[]
  MessageLog       MessageLog[]
  User             User[]
  WhatsAppSession  WhatsAppSession?
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model User {
  id        String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId  String    @db.Uuid
  email     String    @unique
  password  String
  name      String
  role      String?   @default("owner")
  createdAt DateTime? @default(now()) @db.Timestamptz(6)
  updatedAt DateTime? @default(now()) @db.Timestamptz(6)
  Tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([tenantId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model WhatsAppSession {
  id         String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId   String    @unique @db.Uuid
  phone      String?
  status     String?   @default("disconnected")
  lastActive DateTime? @db.Timestamptz(6)
  createdAt  DateTime? @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime? @default(now()) @db.Timestamptz(6)
  Tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([tenantId])
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Broadcast {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId    String    @db.Uuid
  message     String
  recipients  String[]  @default([])
  sentCount   Int?      @default(0)
  failedCount Int?      @default(0)
  status      String?   @default("pending")
  scheduledAt DateTime? @db.Timestamptz(6)
  completedAt DateTime? @db.Timestamptz(6)
  createdAt   DateTime? @default(now()) @db.Timestamptz(6)
  Tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([tenantId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model DailyStat {
  id             String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId       String    @db.Uuid
  date           DateTime  @db.Date
  messagesIn     Int?      @default(0)
  messagesOut    Int?      @default(0)
  aiResponses    Int?      @default(0)
  newLeads       Int?      @default(0)
  broadcastsSent Int?      @default(0)
  createdAt      DateTime? @default(now()) @db.Timestamptz(6)
  Tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([tenantId, date], map: "DailyStat_tenant_date_idx")
  @@index([tenantId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model KnowledgeEntry {
  id        String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId  String    @db.Uuid
  category  String
  title     String
  content   String
  isActive  Boolean?  @default(true)
  createdAt DateTime? @default(now()) @db.Timestamptz(6)
  updatedAt DateTime? @default(now()) @db.Timestamptz(6)
  Tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([tenantId, category], map: "KnowledgeEntry_category_idx")
  @@index([tenantId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Lead {
  id           String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId     String    @db.Uuid
  phone        String
  name         String?
  firstMessage String?
  messageCount Int?      @default(1)
  lastContact  DateTime? @default(now()) @db.Timestamptz(6)
  tags         String[]  @default([])
  lastManualReplyAt DateTime? @db.Timestamptz(6)
  humanOverrideUntil DateTime? @db.Timestamptz(6)
  createdAt    DateTime? @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime? @default(now()) @db.Timestamptz(6)
  Tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([tenantId, phone], map: "Lead_tenant_phone_idx")
  @@index([tenantId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model MessageLog {
  id        String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId  String    @db.Uuid
  direction String
  phone     String
  message   String
  language  String?
  aiModel   String?
  repliedBy String?   @default("NONE")
  repliedAt DateTime? @db.Timestamptz(6)
  pendingReplyId String? @db.Uuid
  createdAt DateTime? @default(now()) @db.Timestamptz(6)
  Tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([tenantId, phone], map: "MessageLog_phone_idx")
  @@index([tenantId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Tenant {
  id               String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name             String
  businessType     String?          @default("general")
  plan             String?          @default("free")
  maxDailyMessages Int?             @default(100)
  isActive         Boolean?         @default(true)
  aiPersonality    String?          @default("professional")
  createdAt        DateTime?        @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime?        @default(now()) @db.Timestamptz(6)
  Broadcast        Broadcast[]
  DailyStat        DailyStat[]
  KnowledgeEntry   KnowledgeEntry[]
  Lead             Lead[]
  MessageLog       MessageLog[]
  AutomationFlow   AutomationFlow[]
  OwnerActivity    OwnerActivity[]
  PendingReply     PendingReply[]
  Template         Template[]
  TenantAutomationSettings TenantAutomationSettings?
  User             User[]
  WhatsAppSession  WhatsAppSession?
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model User {
  id        String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId  String    @db.Uuid
  email     String    @unique
  password  String
  name      String
  role      String?   @default("owner")
  createdAt DateTime? @default(now()) @db.Timestamptz(6)
  updatedAt DateTime? @default(now()) @db.Timestamptz(6)
  OwnerActivity OwnerActivity[]
  Tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([tenantId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model WhatsAppSession {
  id             String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId       String    @unique @db.Uuid
  sessionId      String?   @default("primary")
  phone          String?
  status         String?   @default("disconnected")
  state          String?   @default("DISCONNECTED")
  qr             String?
  qrCreatedAt    DateTime? @db.Timestamptz(6)
  reason         String?
  lastActive     DateTime? @db.Timestamptz(6)
  lastSeenAt     DateTime? @db.Timestamptz(6)
  connectedAt    DateTime? @db.Timestamptz(6)
  disconnectedAt DateTime? @db.Timestamptz(6)
  createdAt      DateTime? @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime? @default(now()) @db.Timestamptz(6)
  Tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([tenantId])
}

/// Tenant-scoped automation settings.
model TenantAutomationSettings {
  id                   String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId             String    @unique @db.Uuid
  autoReplyMode        String?   @default("DELAYED")
  replyDelayMinutes    Int?      @default(20)
  offlineGraceMinutes  Int?      @default(10)
  workingHours         Json?
  enableHumanOverride  Boolean?  @default(true)
  humanOverrideMinutes Int?      @default(30)
  createdAt            DateTime? @default(now()) @db.Timestamptz(6)
  updatedAt            DateTime? @default(now()) @db.Timestamptz(6)
  Tenant               Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([tenantId])
}

/// Owner/staff activity used for offline detection.
model OwnerActivity {
  id                String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId          String    @db.Uuid
  userId            String    @db.Uuid
  lastActiveAt      DateTime? @default(now()) @db.Timestamptz(6)
  lastHeartbeatAt   DateTime? @db.Timestamptz(6)
  lastManualReplyAt DateTime? @db.Timestamptz(6)
  source            String?
  createdAt         DateTime? @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime? @default(now()) @db.Timestamptz(6)
  Tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  User              User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([tenantId, userId], map: "OwnerActivity_tenant_user_idx")
  @@index([tenantId, lastActiveAt])
}

/// Saved message templates.
model Template {
  id          String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId    String       @db.Uuid
  name        String
  content     String
  variables   Json?
  createdAt   DateTime?    @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime?    @default(now()) @db.Timestamptz(6)
  Tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  FlowAction  FlowAction[]
  PendingReply PendingReply[]

  @@index([tenantId])
}

/// n8n-like automation flow definition.
model AutomationFlow {
  id          String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId    String         @db.Uuid
  name        String
  enabled     Boolean?       @default(true)
  priority    Int?           @default(0)
  createdAt   DateTime?      @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime?      @default(now()) @db.Timestamptz(6)
  Tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  Trigger     FlowTrigger?
  Condition   FlowCondition[]
  Action      FlowAction[]
  PendingReply PendingReply[]

  @@index([tenantId, enabled, priority])
}

model FlowTrigger {
  id         String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  flowId     String         @unique @db.Uuid
  tenantId   String         @db.Uuid
  type       String         @default("INCOMING_MESSAGE")
  value      Json?
  config     Json?
  createdAt  DateTime?      @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime?      @default(now()) @db.Timestamptz(6)
  Flow       AutomationFlow @relation(fields: [flowId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([tenantId])
}

model FlowCondition {
  id         String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  flowId     String         @db.Uuid
  tenantId   String         @db.Uuid
  type       String
  operator   String?
  value      Json?
  sortOrder  Int?           @default(0)
  createdAt  DateTime?      @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime?      @default(now()) @db.Timestamptz(6)
  Flow       AutomationFlow @relation(fields: [flowId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([flowId, sortOrder])
  @@index([tenantId])
}

model FlowAction {
  id         String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  flowId     String         @db.Uuid
  tenantId   String         @db.Uuid
  type       String
  config     Json?
  sortOrder  Int?           @default(0)
  templateId String?        @db.Uuid
  createdAt  DateTime?      @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime?      @default(now()) @db.Timestamptz(6)
  Flow       AutomationFlow @relation(fields: [flowId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  Template   Template?      @relation(fields: [templateId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([flowId, sortOrder])
  @@index([templateId])
  @@index([tenantId])
}

/// Scheduled reply queue.
model PendingReply {
  id          String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId    String         @db.Uuid
  messageLogId String?       @db.Uuid
  phone       String
  status      String?        @default("pending")
  sourceType  String?        @default("DEFAULT")
  scheduledAt DateTime       @db.Timestamptz(6)
  expiresAt   DateTime       @db.Timestamptz(6)
  attempts    Int?           @default(0)
  payload     Json?
  lastError   String?
  sentAt      DateTime?      @db.Timestamptz(6)
  cancelledAt DateTime?      @db.Timestamptz(6)
  flowId      String?        @db.Uuid
  templateId  String?        @db.Uuid
  createdAt   DateTime?      @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime?      @default(now()) @db.Timestamptz(6)
  Tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  Flow        AutomationFlow? @relation(fields: [flowId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  Template    Template?      @relation(fields: [templateId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([tenantId, status, scheduledAt], map: "PendingReply_queue_idx")
  @@index([tenantId, phone])
  @@index([messageLogId])
}
